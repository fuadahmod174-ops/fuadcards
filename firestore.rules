rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: players
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - name: string (required)
    //   - username: string (required, unique)
    //   - email: string (required)
    //   - photoURL: string (required)
    //   - age: number (optional)
    //   - gender: string (optional)
    //   - bio: string (optional)
    //   - favAnime: string (optional)
    //   - setupComplete: bool (required)
    //   - totalPower: number (required)
    //   - cardsToday: number (required)
    //   - activeMinutes: number (optional)
    //
    // Collection: cards
    // Document ID: cardId
    // Fields:
    //   - ownerId: string (required)
    //   - characterName: string (required)
    //   - animeSource: string (required)
    //   - raw_power: number (required)
    //   - status: string (required)
    //   - imageUrl: string (required)
    //
    // Collection: orders
    // Document ID: orderId
    // Fields:
    //   - userId: string (required)
    //   - cardId: string (required)
    //   - status: string (required)
    //
    // Collection: notifications
    // Document ID: notificationId
    // Fields:
    //   - userId: string (required)
    //   - read: bool (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "fuadeditingzone@gmail.com" || 
        request.auth.token.email == "selectedlegendbusiness@gmail.com" || 
        request.auth.token.email == "fuadahmod174@gmail.com" ||
        request.auth.token.email == "mythictutorial@gmail.com"
      );
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email']) &&
             data.uid is string &&
             data.displayName is string &&
             data.displayName.size() < 100 &&
             data.email is string;
    }

    function isValidCard(data) {
      return data.keys().hasAll(['ownerId', 'characterName', 'raw_power', 'status']) &&
             data.ownerId is string &&
             data.characterName is string &&
             data.characterName.size() < 100 &&
             data.raw_power is number &&
             data.status in ['forge', 'saved', 'ordered'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /players/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidPlayer(request.resource.data);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /cards/{cardId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid && isValidCard(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || 
        request.auth.token.email == resource.data.userId
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || 
        request.auth.token.email == resource.data.userId
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || 
        request.auth.token.email == resource.data.userId
      );
    }
  }
}
